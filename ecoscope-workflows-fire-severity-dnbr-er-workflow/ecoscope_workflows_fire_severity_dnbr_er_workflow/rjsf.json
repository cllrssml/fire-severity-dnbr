{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Workflow Details"
    },
    "er_connection": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "EarthRanger"
    },
    "gee_connection": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/GoogleEarthEngineConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Earth Engine"
    },
    "fire_event": {
      "additionalProperties": false,
      "properties": {
        "event_type": {
          "title": "Event Type",
          "type": "string",
          "description": "EarthRanger event type value for fire events (e.g. 'controlled_burn'). To find it: in EarthRanger go to Admin \u2192 Event Categories \u2192 click your fire category \u2192 select the event type and copy the 'Value' field (not the display name \u2014 the short lowercase slug). Must match exactly."
        },
        "serial_number": {
          "minimum": 1,
          "title": "Serial Number",
          "type": "integer",
          "description": "EarthRanger serial number of the fire event (e.g. 472259). To find it: go to Reports \u2192 Events in EarthRanger, locate your fire event, and note the number in the '#' or Serial Number column. Each event has a unique serial number \u2014 use this to select exactly one fire."
        }
      },
      "required": [
        "event_type",
        "serial_number"
      ],
      "type": "object",
      "title": "Fire Event"
    },
